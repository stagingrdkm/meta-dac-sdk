From 1cd83f9c123cbc4e8460d83fb4b633833ca41476 Mon Sep 17 00:00:00 2001
From: Ansu Mathew <Ansu_Mathew@comcast.com>
Date: Thu, 20 Mar 2025 06:02:10 +0000
Subject: [PATCH] DELIA 64727 Prealloc secure memory before decrypt rebased

---
 Source/ocdm/adapter/rdk/open_cdm_adapter.cpp | 9 ++++++++-
 1 file changed, 8 insertions(+), 1 deletion(-)

diff --git a/Source/ocdm/adapter/rdk/open_cdm_adapter.cpp b/Source/ocdm/adapter/rdk/open_cdm_adapter.cpp
index 39ff8eb..a5532c2 100644
--- a/Source/ocdm/adapter/rdk/open_cdm_adapter.cpp
+++ b/Source/ocdm/adapter/rdk/open_cdm_adapter.cpp
@@ -438,7 +438,14 @@ OpenCDMError opencdm_gstreamer_session_decrypt_buffer(struct OpenCDMSession* ses
 
             if(total_encrypted_bytes > 0) {
                uint8_t* svpData;
-               uint32_t dataBlockSize = gst_svp_allocate_data_block(session->GetSVPContext(), (void**) &svpData, mappedDataSize, mappedDataSize);
+               const gboolean needSecureMemoryPrealloc = (streamProperties.media_type == MediaType_Video)
+                                                       && gst_svp_context_supports_memory_prealloc(session->SessionPrivateData());
+
+               uint32_t dataBlockSize = gst_svp_allocate_data_block(session->SessionPrivateData(),
+                                                                    (void**) &svpData,
+                                                                    mappedDataSize,
+                                                                    mappedDataSize,
+                                                                    needSecureMemoryPrealloc);
 
                void * encryptedData = reinterpret_cast<uint8_t *>(gst_svp_header_get_start_of_data(session->GetSVPContext(), svpData));
 
-- 
2.48.0

